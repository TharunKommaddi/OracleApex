-- =====================================================
-- STEP 14: EXPORT SODA COLLECTIONS
-- =====================================================
SELECT '-- SODA Collection: ' || collection_name || CHR(10) ||
       '======================================================' || CHR(10) ||
       'METADATA: ' || CHR(10) || metadata || CHR(10) ||
       '======================================================' || CHR(10)
FROM user_soda_collections
ORDER BY collection_name;
