-- =====================================================
-- STEP 11: EXPORT DATABASE LINKS
-- =====================================================
SELECT '-- Database Link: ' || db_link || CHR(10) ||
       '======================================================' || CHR(10) ||
       DBMS_METADATA.GET_DDL('DB_LINK', db_link) || CHR(10) ||
       '======================================================' || CHR(10)
