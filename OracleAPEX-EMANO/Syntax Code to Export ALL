SELECT '-- Function: ' || object_name || CHR(10) ||
       '======================================================' || CHR(10) ||
       DBMS_METADATA.GET_DDL('FUNCTION', object_name) || CHR(10) ||
       '======================================================' || CHR(10)
FROM user_objects
WHERE object_type = 'FUNCTION'
